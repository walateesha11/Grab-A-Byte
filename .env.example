# GrabAByte — Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# On Railway, MYSQL_URL is injected automatically when you link a
# MySQL service to this deployment — you do not need to set it manually.

# ── Database ──────────────────────────────────────────────────────────────────
# Full MySQL connection URL.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Railway example: mysql://root:secret@containers-us-west-1.railway.app:6543/railway
MYSQL_URL=mysql://root:password@localhost:3306/grababyte_db

# ── Flask ─────────────────────────────────────────────────────────────────────
# A long random string used to sign Flask sessions.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Set to "development" to enable Flask's debug mode and auto-reloader.
# Leave as "production" (or unset) on Railway.
FLASK_ENV=production

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Flask/Gunicorn server listens on.
# Railway sets this automatically — do not override it in production.
PORT=5000
